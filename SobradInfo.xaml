<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Naidis_TARpe24.SobradInfo"
             Title="Sõprade Info">

    <VerticalStackLayout Spacing="15" Padding="20">

        <Label Text="Sõnumi saatmine" 
           FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />

        <Entry x:Name="entry_phone" 
           Placeholder="Sisesta telefoni number" 
           Keyboard="Telephone" />

        <Button Text="Saada SMS" 
            Clicked="Saada_sms_Clicked" 
            BackgroundColor="Black" TextColor="Red" />

        <BoxView HeightRequest="1" Color="Gray" />

        <Entry x:Name="entry_email" 
           Placeholder="Sisesta e-maili aadress" 
           Keyboard="Email" />

        <Button Text="Saada E-mail" 
            Clicked="Saada_email_Clicked" 
            BackgroundColor="Black" TextColor="Red" />

        <BoxView HeightRequest="1" Color="Gray" />

        <Button Text="Tee Foto" 
            Clicked="OnTeeFotoClicked" 
            BackgroundColor="Black" TextColor="Red" />

        <Image x:Name="profiiliPilt" 
           HeightRequest="200" HorizontalOptions="Center" />

    </VerticalStackLayout>
</ContentPage>
