<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Naidis_TARpe24.OOP"
             x:Name="ThisPage">

    <AbsoluteLayout x:Name="GameField">

        <VerticalStackLayout AbsoluteLayout.LayoutBounds="0.5, 0.2, 300, 320"
                             AbsoluteLayout.LayoutFlags="PositionProportional"
                             Spacing="15" Padding="20"
                             BackgroundColor="Green">

            <Label Text="MÄNGU SEADED" HorizontalOptions="Center" FontAttributes="Bold" />

            <Picker x:Name="ThemePicker" Title="Vali teema" />

            <Label x:Name="ScoreLabel" 
                   Text="Punktid: 0" 
                   FontSize="28"
                   TextColor="{DynamicResource DynamicTextColor}"
                   FontFamily="{DynamicResource DynamicFont}"
                   HorizontalOptions="Center" />

            <Button Text="ALUSTA MÄNGU" 
                    Clicked="OnStartClicked"
                    BackgroundColor="LightPink" 
                    TextColor="Black"
                    HeightRequest="50" />

            <Label Text="Locked in!" 
                   HorizontalOptions="Center" 
                   FontSize="11" />
        </VerticalStackLayout>

        <Image x:Name="TargetImage"
               Aspect="AspectFit"
               IsVisible="False"
               HeightRequest="100"
               WidthRequest="100">
            <Image.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnImageTapped" />
            </Image.GestureRecognizers>
        </Image>

    </AbsoluteLayout>
</ContentPage>